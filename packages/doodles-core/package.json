{
  "name": "@benkalegin/doodles-core",
  "version": "0.3.8",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./testing": "./src/testing/index.ts"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./testing": {
        "types": "./dist/testing/index.d.ts",
        "default": "./dist/testing/index.js"
      }
    },
    "registry": "https://npm.pkg.github.com"
  },
  "description": "Doodle types, validation, migration, and a relational-layout testing DSL.",
  "license": "MIT",
  "author": "Ben Kalegin",
  "repository": {
    "type": "git",
    "url": "https://github.com/BenKalegin/doodles.git",
    "directory": "packages/doodles-core"
  }
}
